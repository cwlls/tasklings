# Tasklings -- Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------
# Required
# -----------------------------------------------------------------

# A long, random string used to sign session cookies and tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# -----------------------------------------------------------------
# Database
# -----------------------------------------------------------------

# Path to the SQLite database file (relative to the project root, or absolute).
DATABASE_PATH=tasklings.db

# -----------------------------------------------------------------
# Session & Auth
# -----------------------------------------------------------------

# How many hours a login session remains valid before expiring.
SESSION_LIFETIME_HOURS=72

# Number of bcrypt rounds for password hashing. Higher = slower but more secure.
# 12 is a good default; lower to 10 for faster tests.
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------
# Localisation
# -----------------------------------------------------------------

# IANA timezone name used for all date logic (daily chore generation, etc.).
HOUSEHOLD_TIMEZONE=America/Chicago

# -----------------------------------------------------------------
# Optional: Email (for password reset delivery)
# -----------------------------------------------------------------

# If not set, password reset tokens are only retrievable by an admin
# via the admin API endpoint. Leave blank to disable email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
